<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron's V8 JavaScript engine (JIT compilation) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Electron/Chromium to allocate executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required because the app loads bundled frameworks (Electron, Chromium) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required: app uses outgoing network connections (HTTP to CDP, image downloads) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Required: app reads/writes user files (output images, configs, sessions) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
